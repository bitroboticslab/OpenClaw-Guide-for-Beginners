  "agents": {
    "defaults": {
      "model": {
        "primary": "siliconflow/Pro/zai-org/GLM-4.7",
        "fallbacks": []
      },
      "models": {
        "_comment_siliconflow_models": "硅基流动模型别名配置",
        "siliconflow/Pro/zai-org/GLM-4.7": {
          "alias": "sili-GLM-4.7"
        },
        "siliconflow/Pro/MiniMaxAI/MiniMax-M2.5": {
          "alias": "sili-MiniMax-M2.5"
        },
        "siliconflow/Pro/moonshotai/Kimi-K2.5": {
          "alias": "sili-moonshot-Kimi-K2.5"
        },
        "_comment_volcengine_models": "火山引擎模型别名配置",
        "volcengine/glm-4.7": {
          "alias": "volcengine-glm-4.7"
        },
        "volcengine/deepseek-v3.2": {
          "alias": "volcengine-deepseek-v3.2"
        },
        "volcengine/kimi-k2-thinking": {
          "alias": "volcengine-kimi-k2-thinking"
        },
        "volcengine/kimi-k2.5": {
          "alias": "volcengine-kimi-k2.5"
        },
        "volcengine/doubao-seed-code": {
          "alias": "volcengine-doubao-seed-code"
        },
        "_comment_bailian_models": "阿里百炼模型别名配置",
        "bailian/qwen-plus-latest": {
          "alias": "qwen-plus-latest"
        },
        "bailian/qwen3-max-2025-09-23": {
          "alias": "qwen3-max-0923"
        },
        "bailian/qwen3-max-preview": {
          "alias": "qwen3-max-preview"
        },
        "bailian/qwen-coder-plus": {
          "alias": "qwen-coder-plus"
        },
        "bailian/kimi-k2-thinking": {
          "alias": "kimi-k2-thinking"
        },
        "bailian/deepseek-v3.2": {
          "alias": "deepseek-v3.2"
        },
        "bailian/glm-4.7": {
          "alias": "glm-4.7"
        }
      },
      "workspace": "~/.openclaw/workspace",
      "memorySearch": {
        "enabled": true,
        "provider": "openai",
        "remote": {
          "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
          "apiKey": "${BAILIAN_API_KEY}",
          "headers": {
            "Accept": "application/json"
          }
        },
        "fallback": "none",
        "model": "text-embedding-v4",
        "store": {
          "path": "~/.openclaw/memory/{agentId}.sqlite",
          "vector": {"enabled": true}
        },
        "sync": {"watch": true},
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "candidateMultiplier": 4
          }
        },
        "cache": {"enabled": true, "maxEntries": 50000}
      },
      "compaction": {"mode": "safeguard"},
      "heartbeat": {"every": "0m"},
      "maxConcurrent": 4,
      "subagents": {"maxConcurrent": 8}
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {"allowInsecureAuth": false},
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    },
    "trustedProxies": ["127.0.0.1", "::1"],
    "tailscale": {"mode": "off", "resetOnExit": false}
  },
  "channels": {
    "_comment": "消息平台配置 - 根据需要启用",
    "ddingtalk": {
      "enabled": false,
      "clientId": "YOUR_DINGTALK_CLIENT_ID",
      "clientSecret": "YOUR_DINGTALK_CLIENT_SECRET",
      "allowFrom": ["*"],
      "name": "OpenClaw机器人"
    },
    "telegram": {
      "enabled": false,
      "botToken": "YOUR_TELEGRAM_BOT_TOKEN",
      "mode": "webhook"
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "plugins": {
    "allow": [
      "feishu",
      "ddingtalk",
      "adp-openclaw"
    ]
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  }
}
